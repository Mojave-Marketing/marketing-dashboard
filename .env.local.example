# Mailchimp API credentials
# API key format: abc123...xyz-us21  (the part after the last dash is your server prefix)
# Get/create one: Mailchimp → profile icon → Extras → API keys → Create A Key
MAILCHIMP_API_KEY=your-api-key-here
MAILCHIMP_SERVER_PREFIX=us21

# Campaign filter
# "title" (default) — matches campaigns whose title contains MAILCHIMP_TITLE_MATCH (case-insensitive)
# "folder" — filters by MAILCHIMP_FOLDER_ID; requires moving campaigns into a Mailchimp folder first
MAILCHIMP_FILTER_MODE=title
MAILCHIMP_TITLE_MATCH=Rep Training
MAILCHIMP_FOLDER_ID=

# Benchmark rates (decimal — 0.26 = 26%) shown in KPI cards and takeaways
BENCHMARK_OPEN_RATE=0.26
BENCHMARK_CLICK_RATE=0.03
